<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Login</title>

  <style>
    body {
      margin: 0;
      height: 100vh;
      background: linear-gradient(to bottom right, #fff6ee, #ffe0c2);
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: Arial, sans-serif;
    }

    .login-box {
      background-color: #ffffff;
      padding: 45px 35px;
      border-radius: 14px;
      width: 420px;
      box-shadow: 0 6px 18px rgba(255, 140, 0, 0.25);
      text-align: center;
    }

    h2 {
      margin-top: 0;
      margin-bottom: 25px;
      color: #b24b00;
      font-size: 32px;
      letter-spacing: 1px;
    }

    label {
      display: block;
      text-align: left;
      margin-bottom: 6px;
      font-size: 14px;
      color: #7a3300;
      font-weight: bold;
    }

    input[type="text"],
    input[type="password"] {
      width: 100%;
      padding: 10px;
      margin-bottom: 18px;
      border: 1px solid #ffcc99;
      border-radius: 8px;
      font-size: 14px;
      box-sizing: border-box;
      background-color: #fffaf5;
    }

    input:focus {
      outline: none;
      border-color: #ff9f43;
      box-shadow: 0 0 6px rgba(255, 159, 67, 0.5);
    }

    button {
      width: 100%;
      padding: 12px;
      background-color: #ff9f43;
      border: none;
      border-radius: 10px;
      color: #5a2500;
      font-size: 17px;
      font-weight: bold;
      cursor: pointer;
      margin-top: 10px;
    }

    button:hover {
      background-color: #ff8c1a;
    }

    .error-message {
      color: #c0392b;
      margin-bottom: 15px;
      font-size: 14px;
    }
  </style>
</head>

<body>

  <div class="login-box">
    <h2>Login</h2>

    <form action="/admin/login" method="POST">
      <label for="email">Email</label>
      <input type="text" id="email" name="email" required />

      <label for="password">Password</label>
      <input type="password" id="password" name="password" required />

      <button type="submit">Login</button>
    </form>
  </div>

</body>
</html>
