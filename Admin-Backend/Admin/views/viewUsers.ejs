<!DOCTYPE html>
<html>
<head>
<title>USERS LIST</title>

<!-- BOOTSTRAP -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #fff6ee;
}

.navbar{
background:linear-gradient(to right,#ffddb8,#ffc184);
padding:15px 40px;
box-shadow:0 2px 8px rgba(255,140,0,0.25);
}

.logo{
color:#9a4200;
font-size:30px;
font-weight:bold;
font-style:italic;
}

.navcontent a{
color:#7a3300;
padding:10px 14px;
text-decoration:none;
font-weight:600;
border-radius:6px;
}

.navcontent a:hover{
background-color:#ffb76b;
}

.logoutbutton{
background-color:#ff9f43;
border:none;
color:#5a2500;
padding:9px 16px;
border-radius:6px;
cursor:pointer;
font-weight:bold;
}

/* PAGE CONTENT */
.container {
    width: 92%;
    margin: 50px auto;
    background: #ffffff;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 14px rgba(255, 165, 0, 0.15);
}

.container h2 {
    color: #9a4200;
    font-family: 'Times New Roman', Times, serif;
    font-weight: 900;
    font-style: italic;
}

/* USERS TABLE */
.user-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 30px;
    background-color: #fffaf4;
    border-radius: 10px;
    overflow: hidden;
}

.user-table th {
    background-color: #ffddb8;
    color: #7a3300;
    padding: 14px;
    text-align: left;
}

.user-table td {
    padding: 14px;
    color: #5c3a20;
    font-family: 'Times New Roman', Times, serif;
    font-weight: 600;
    border-bottom: 1px solid #ffe2c7;
}

.user-table tr:hover {
    background-color: #fff1e2;
}

/* STATUS COLORS */
.active-status {
    color: #e67e22;
    font-weight: bold;
}

.inactive-status {
    color: #b3541e;
    font-weight: bold;
}

/* VIEW BUTTON */
.view-link {
    text-decoration: none;
    padding: 6px 14px;
    background-color: #ff9f43;
    color: #5a2500;
    border-radius: 6px;
    font-weight: 600;
}

.view-link:hover {
    background-color: #ff8c1a;
}

/* PAGINATION */
.pagination {
    text-align: center;
    margin-top: 30px;
    justify-content: center;
}

.pagination span {
    display: inline-block;
    margin: 5px 6px;
    padding: 9px 15px;
    border-radius: 8px;
    background-color: #ffe0c2;
    color: #7a3300;
    font-weight: 600;
}

.pagination .active {
    background-color: #ff9f43;
    color: #5a2500;
}
</style>

</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg">

<div class="container-fluid">

<span class="logo">RECIPEbox</span>

<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
<span class="navbar-toggler-icon"></span>
</button>

<div class="collapse navbar-collapse justify-content-end" id="navbarMenu">

<div class="navcontent d-flex flex-column flex-lg-row gap-3 align-items-lg-center mt-3 mt-lg-0">

<a href="/admin/home">Home</a>
<a href="/admin/viewusers">View Users</a>
<a href="/admin/mostviewed">Most Viewed</a>

<a href="/admin/logout" class="logoutbutton">Logout</a>
</div>

</div>

</div>

</nav>

<!-- CONTENT -->
<div class="container">

<h2>Users List</h2>

<table class="user-table">

<thead>
<tr>
<th>Creator Name</th>
<th>Status</th>
<th>View Profile</th>
</tr>
</thead>

<tbody>

<% users.forEach(function(user){ %>

<tr>

<td><%= user.name %></td>

<td>
<span class="<%= user.status === 'Blocked' ? 'inactive-status' : 'active-status' %>">
<%= user.status %>
</span>
</td>

<td>
<a href="/admin/userprofile/<%= user._id %>?page=<%= currentPage %>" class="view-link">View</a>
</td>

</tr>

<% }) %>

</tbody>

</table>

<!-- PAGINATION -->
<div class="pagination">

<% if(currentPage > 1){ %>
<a href="/admin/viewusers?page=<%= currentPage - 1 %>">
<span>&laquo;</span>
</a>
<% } %>

<% for(let i = 1; i <= totalPages; i++){ %>

<a href="/admin/viewusers?page=<%= i %>">
<span class="<%= currentPage === i ? 'active' : '' %>"><%= i %></span>
</a>

<% } %>

<% if(currentPage < totalPages){ %>
<a href="/admin/viewusers?page=<%= currentPage + 1 %>">
<span>&raquo;</span>
</a>
<% } %>

</div>

</div>

<!-- BOOTSTRAP JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>