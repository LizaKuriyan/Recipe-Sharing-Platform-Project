<!DOCTYPE html>
<html>
<head>
    <title><%= recipe.title %> | RECIPEbox</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #fff6ee;
        }

        /* NAVBAR */
        .navbar {
            background: linear-gradient(to right, #ffddb8, #ffc184);
            padding: 15px 40px;
            box-shadow: 0 2px 8px rgba(255,140,0,0.25);
        }

        .logo {
            color: #9a4200;
            font-size: 30px;
            font-weight: bold;
            font-style: italic;
        }

        .navcontent a {
            color: #7a3300;
            padding: 10px 14px;
            text-decoration: none;
            font-weight: 600;
            border-radius: 6px;
        }

        .navcontent a:hover {
            background-color: #ffb76b;
        }

        .logoutbutton {
            background-color: #ff9f43;
            border: none;
            color: #5a2500;
            padding: 9px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
        }

        .logoutbutton:hover {
            background-color: #ff8c1a;
        }

        /* RECIPE CONTENT */
        .container {
            width: 92%;
            margin: 40px auto;
            background: #ffffff;
            padding: 35px;
            border-radius: 14px;
            box-shadow: 0 4px 14px rgba(255,165,0,0.15);
        }

        .recipe-header {
            display: flex;
            flex-direction: column;
            gap: 30px;
            align-items: center;
        }

        .recipe-image {
            width: 100%;
            height: 400px;
            border-radius: 12px;
            object-fit: cover;
            box-shadow: 0 3px 10px rgba(255,165,0,0.2);
        }

        .recipe-info h2 {
            margin: 0;
            color: #9a4200;
            text-align: center;
            font-family: 'Times New Roman', Times, serif;
            font-weight: 900;
            font-style: italic;
            font-size: 30px;
        }

        .creator {
            margin-top: 10px;
            font-weight: bold;
            color: #6b3a12;
            font-size: 15px;
            font-style: italic;
            text-align: center;
        }

        .section {
            margin-top: 35px;
        }

        .section h3 {
            color: #9a4200;
            font-family: 'Times New Roman', Times, serif;
            font-style: italic;
            font-size: 24px;
            margin-bottom: 10px;
        }

        .content-text {
            color: #5c3a20;
            line-height: 1.8;
            font-size: 17px;
            font-weight: 600;
            font-family: 'Times New Roman', Times, serif;
        }

        .back-btn {
            margin-top: 40px;
            display: inline-block;
            text-decoration: none;
            padding: 10px 18px;
            background-color: #ff9f43;
            color: #5a2500;
            border-radius: 8px;
            font-weight: bold;
        }

        .back-btn:hover {
            background-color: #ff8c1a;
        }
    </style>
</head>

<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">
            <span class="logo">RECIPEbox</span>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarMenu">
                <div class="navcontent d-flex flex-column flex-lg-row gap-3 align-items-lg-center mt-3 mt-lg-0">
                    <a href="/admin/home">Home</a>
                    <a href="/admin/viewusers">View Users</a>
                    <a href="/admin/mostviewed">Most Viewed</a>
                    <a href="/admin/logout" class="logoutbutton">Logout</a>                
                </div>
            </div>
        </div>
    </nav>

    <!-- RECIPE CONTENT -->
    <div class="container">
        <div class="recipe-header">
            <img src="<%= recipe.image %>" class="recipe-image">
            <div class="recipe-info">
                <h2><%= recipe.title %></h2>
                <div class="creator">Created by: <%= recipe.creator.name %></div>
            </div>
        </div>

        <div class="section">
            <h3>Ingredients:</h3>
            <div class="content-text">
                <% recipe.ingredients.forEach((item, index) => { %>
                    <%= index + 1 %>. <%= item %><br>
                <% }) %>
            </div>
        </div>

        <div class="section">
            <h3>Steps to Follow:</h3>
            <div class="content-text">
                <% recipe.steps.forEach((step, index) => { %>
                    Step <%= index + 1 %>. <%= step %><br>
                <% }) %>
            </div>
        </div>

        <div class="section">
            <h3>Cooking Time:</h3>
            <div class="content-text"><%= recipe.cookingTime %> mins</div>
        </div>

        <div class="section">
            <h3>Difficulty Level:</h3>
            <div class="content-text"><%= recipe.difficultyLevel %></div>
        </div>

        <!-- BACK BUTTON -->
        <a href="<% if(from === 'home'){ %>
                 /admin/home?page=<%= currentPage %><% } 
                 else if(from === 'userprofile'){ %>
                 /admin/userprofile/<%= userId %>?page=<%= currentPage %><% } 
                 else if(from === 'mostviewed'){ %>
                 /admin/mostviewed?page=<%= currentPage %>
                 <% } %>" class="back-btn">← Back</a>
    </div>

    <!-- BOOTSTRAP JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>