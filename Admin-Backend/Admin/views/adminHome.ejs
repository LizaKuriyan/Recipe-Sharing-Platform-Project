<!DOCTYPE html>
<html>
<head>
<title>HOME PAGE</title>

<meta name="viewport" content="width=device-width, initial-scale=1">

<!-- BOOTSTRAP -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#fff6ee;
font-family: Arial, sans-serif;
}

/* NAVBAR */

.navbar{
background:linear-gradient(to right,#ffddb8,#ffc184);
padding:15px 40px;
box-shadow:0 2px 8px rgba(255,140,0,0.25);
}

.logo{
color:#9a4200;
font-size:30px;
font-weight:bold;
font-style:italic;
}

.navcontent a{
color:#7a3300;
padding:10px 14px;
text-decoration:none;
font-weight:600;
border-radius:6px;
}

.navcontent a:hover{
background-color:#ffb76b;
}

.logoutbutton{
background-color:#ff9f43;
border:none;
color:#5a2500;
padding:9px 16px;
border-radius:6px;
cursor:pointer;
font-weight:bold;
}

/* CARD */

.recipe-card{
border-radius:14px;
overflow:hidden;
box-shadow:0 4px 12px rgba(255,140,0,0.18);
transition:0.3s;
background:#fff4ea;
}

.recipe-card:hover{
transform:translateY(-5px);
}

.recipe-card img{
height:200px;
object-fit:cover;
width:100%;
}

.recipe-info{
padding:10px;
}

.recipe-title{
color:#9a4200;
font-style:italic;
font-weight:bold;
}

.recipe-creator{
color:#7a3300;
font-style:italic;
}

/* PAGINATION */

.pagination .page-link{
background:#ffe0c2;
border:none;
color:#7a3300;
margin:10px;
padding: 9px 15px;
border-radius:8px;
}

.pagination .active .page-link{
background:#ff9f43;
color:#5a2500;
}

</style>

</head>

<body>

<!-- NAVBAR -->

<nav class="navbar navbar-expand-lg">

<div class="container-fluid">

<span class="logo">RECIPEbox</span>

<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
<span class="navbar-toggler-icon"></span>
</button>

<div class="collapse navbar-collapse justify-content-end" id="navbarMenu">

<div class="navcontent d-flex flex-column flex-lg-row gap-3 align-items-lg-center mt-3 mt-lg-0">

<a href="/admin/home">Home</a>

<a href="/admin/viewusers">View Users</a>

<a href="/admin/mostviewed">Most Viewed</a>

<a href="/admin/logout" class="logoutbutton">Logout</a>
</div>

</div>

</div>

</nav>


<!-- PAGE CONTENT -->

<div class="container mt-5">

<h2 class="mb-4" style="color:#9a4200;font-style:italic;font-family: 'Times New Roman', Times, serif;font-weight: 900;">All Recipes</h2>

<div class="row g-4">

<% recipes.forEach(recipe => { %>

<div class="col-xl-4 col-lg-4 col-md-6 col-sm-12">

<a href="/admin/viewrecipe/<%= recipe._id %>?page=<%= currentPage %>&from=home"style="text-decoration:none">

<div class="recipe-card">

<img src="<%= recipe.image %>">

<div class="recipe-info">

<div class="recipe-title">
<%= recipe.title %>
</div>

<div class="recipe-creator">
Creator: <%= recipe.creator.name %>
</div>

</div>

</div>

</a>

</div>

<% }) %>

</div>


<!-- PAGINATION -->

<nav class="mt-5">

<ul class="pagination justify-content-center">

<% if(currentPage > 1){ %>

<li class="page-item">
<a class="page-link" href="/admin/home?page=<%= currentPage - 1 %>">
&laquo;
</a>
</li>

<% } %>


<% for(let i=1;i<=totalPages;i++){ %>

<li class="page-item <%= currentPage === i ? 'active' : '' %>">

<a class="page-link" href="/admin/home?page=<%= i %>">
<%= i %>
</a>

</li>

<% } %>


<% if(currentPage < totalPages){ %>

<li class="page-item">
<a class="page-link" href="/admin/home?page=<%= currentPage + 1 %>">
&raquo;
</a>
</li>

<% } %>

</ul>

</nav>

</div>


<!-- BOOTSTRAP JS -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>